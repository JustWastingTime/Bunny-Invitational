{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bunny-invitational/team",
  "title": "Team",
  "type": "object",
  "required": ["id", "name", "categories"],
  "properties": {
    "id": { "type": "string", "description": "Slug used in match files, e.g. dust-bunny" },
    "name": { "type": "string", "description": "Display name, e.g. Dust Bunny" },
    "shortName": { "type": "string", "description": "Short label for compact UI" },
    "tagline": { "type": "string", "description": "Optional subtitle shown under team name" },
    "color": { "type": "string", "description": "Team accent color (hex)" },
    "categories": {
      "type": "object",
      "required": ["sprint", "mile", "medium", "long", "dirt"],
      "properties": {
        "sprint": { "$ref": "#/$defs/roster" },
        "mile": { "$ref": "#/$defs/roster" },
        "medium": { "$ref": "#/$defs/roster" },
        "long": { "$ref": "#/$defs/roster" },
        "dirt": { "$ref": "#/$defs/roster" }
      }
    }
  },
  "$defs": {
    "roster": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "$ref": "#/$defs/member" }
    },
    "member": {
      "type": "object",
      "required": ["trainer", "uma"],
      "properties": {
        "trainer": { "type": "string" },
        "locked": {
          "type": "boolean",
          "description": "When true, team editor treats this roster slot as complete and read-only"
        },
        "uma": { "$ref": "#/$defs/uma" }
      }
    },
    "uma": {
      "type": "object",
      "required": ["name"],
      "anyOf": [
        { "required": ["spriteId"] },
        { "required": ["characterId"] }
      ],
      "properties": {
        "name": { "type": "string" },
        "spriteId": {
          "description": "Preferred sprite filename key under assets/characters/ (e.g. 1001 for 1001.png)",
          "type": ["string", "integer"]
        },
        "characterId": { "type": "string", "description": "Legacy sprite filename key under assets/characters/" },
        "rating": { "type": "string", "description": "e.g. S, SS, UMA" },
        "style": { "type": "string", "enum": ["runaway", "front", "pace", "late", "end"] },
        "aptitudes": {
          "type": "object",
          "description": "Aptitude grades for terrain, distance, and preferred style",
          "properties": {
            "terrain": { "type": "string", "enum": ["S", "A", "B", "C", "D", "E", "F", "G"] },
            "distance": { "type": "string", "enum": ["S", "A", "B", "C", "D", "E", "F", "G"] },
            "style": { "type": "string", "enum": ["S", "A", "B", "C", "D", "E", "F", "G"] }
          }
        },
        "stats": {
          "type": "object",
          "properties": {
            "speed": { "type": "integer" },
            "stamina": { "type": "integer" },
            "power": { "type": "integer" },
            "guts": { "type": "integer" },
            "wisdom": { "type": "integer" }
          }
        },
        "skills": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
